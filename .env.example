# ============================================
# X2 - Environment Variables
# ============================================
# 이 파일을 .env.local로 복사하여 사용하세요.
# cp .env.example .env.local

# ---- Database ----
# PostgreSQL 연결 문자열 (Supabase 또는 로컬 Docker)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/x2?schema=public"

# Prisma Direct URL (connection pooling 우회, 마이그레이션용)
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/x2?schema=public"

# ---- Authentication (Auth.js) ----
# Auth.js 시크릿 키 (npx auth secret 으로 생성)
AUTH_SECRET="your-auth-secret-here"

# Auth.js URL (로컬 개발 시)
AUTH_URL="http://localhost:3000"

# Google OAuth 클라이언트 (Google Cloud Console에서 발급)
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# 개발 모드 로그인 (true 시 이메일만으로 로그인 가능, 프로덕션에서는 반드시 삭제)
AUTH_DEV_LOGIN="true"

# ---- Redis ----
# Redis 연결 URL (Upstash 또는 로컬 Docker)
REDIS_URL="redis://localhost:6379"

# ---- AI Orchestration ----
# OpenAI API 키 (https://platform.openai.com)
OPENAI_API_KEY="your-openai-api-key"

# Anthropic Claude API 키 (https://console.anthropic.com)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# AI 기본 provider (openai | anthropic | mock)
AI_DEFAULT_PROVIDER="mock"

# AI 개발 모드 (true 시 mock provider 사용, API 키 불필요)
AI_DEV_MODE="true"

# AI 비용 추적 활성화
AI_COST_TRACKING_ENABLED="true"

# AI Mock 응답 지연 시간 (ms, 개발 모드에서 실제 응답 시간 시뮬레이션)
AI_MOCK_LATENCY_MS="500"

# ---- Social Media APIs ----
# YouTube Data API v3 키 (Google Cloud Console에서 발급)
YOUTUBE_API_KEY="your-youtube-api-key"

# Instagram Graph API (Meta Business Suite에서 발급)
INSTAGRAM_ACCESS_TOKEN="your-instagram-access-token"

# TikTok Display API (TikTok Developer Portal에서 발급)
TIKTOK_ACCESS_TOKEN="your-tiktok-access-token"

# X (Twitter) API v2 Bearer Token (developer.x.com에서 발급, Basic tier 이상)
X_API_BEARER_TOKEN="your-x-bearer-token"

# ---- Cron ----
# Vercel Cron 인증 시크릿 (프로덕션용)
CRON_SECRET="your-cron-secret"

# ---- Payments ----
# Stripe API 키 (https://dashboard.stripe.com)
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"

# Stripe Webhook 시크릿 (stripe listen --forward-to 로 확인)
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# ---- Supabase ----
# Supabase 프로젝트 URL (https://app.supabase.com 에서 확인)
SUPABASE_URL="https://your-project.supabase.co"

# Supabase 공개 Anon 키
SUPABASE_ANON_KEY="your-supabase-anon-key"

# ---- Notification External Delivery ----
# Email 발송 API 키 (Resend: https://resend.com, 또는 SendGrid 등)
NOTIFICATION_EMAIL_API_KEY=""
# Email 발송 API URL (기본: Resend)
NOTIFICATION_EMAIL_API_URL="https://api.resend.com/emails"
# Email 발신자 주소
NOTIFICATION_EMAIL_FROM="notifications@x2.app"
# Webhook 알림 URL (Slack Incoming Webhook, Discord, 또는 커스텀 엔드포인트)
NOTIFICATION_WEBHOOK_URL=""
# Webhook HMAC 서명 시크릿 (선택)
NOTIFICATION_WEBHOOK_SECRET=""

# ---- Search Data Sources ----
# 네이버 검색/DataLab API (https://developers.naver.com)
# 블로그, 뉴스, 카페, 지식iN, DataLab 모두 동일 키 사용
# 무료 발급, 일일 25,000건 (DataLab은 1,000건)
NAVER_CLIENT_ID=""
NAVER_CLIENT_SECRET=""

# Google Ads Keyword Planner (https://ads.google.com/aw/apicenter)
# 광고 계정 + Standard Access 필요
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_REFRESH_TOKEN=""
GOOGLE_ADS_CUSTOMER_ID=""

# SerpAPI (https://serpapi.com) — Google SERP, Trends, Related Searches
# $50/5,000 searches (Startup plan)
SERP_API_KEY=""

# DataForSEO (https://dataforseo.com) — 가장 포괄적인 검색 데이터
# $0.002/task (종량제)
DATAFORSEO_LOGIN=""
DATAFORSEO_PASSWORD=""
# Sandbox 모드 (true 시 무료 테스트 데이터 사용)
DATAFORSEO_SANDBOX="true"

# Google Trends Proxy (pytrends 기반 자체 프록시, SerpAPI 대안)
# 별도 서버 필요 — 없으면 SerpAPI 경유
GOOGLE_TRENDS_PROXY_URL=""

# NewsAPI.org (https://newsapi.org) — 글로벌 뉴스
# 무료: 100건/일, Business: 250,000건/월
NEWS_API_KEY=""

# ---- App ----
# 앱 URL (로컬 개발 시)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
