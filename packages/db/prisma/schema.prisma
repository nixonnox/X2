// ============================================

/// 검색 경로 — 특정 시드 키워드에서 파생된 검색 흐름 기록
model SearchPath {
  id      String      @id @default(cuid())
  queryId String
  query   IntentQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)

  fromKeyword String
  toKeyword   String
  strength    Float          @default(0) // 0.0~1.0
  phase       TemporalPhase
  intent      IntentCategory
  pathType    SearchPathType @default(DIRECT)

  createdAt DateTime @default(now())

  @@unique([queryId, fromKeyword, toKeyword])
  @@index([queryId])
  @@map("search_paths")
}

// ============================================
// Listening Mind: Persona
// ============================================

/// 검색 의도 기반 자동 생성된 페르소나
model Persona {
  id      String      @id @default(cuid())
  queryId String
  query   IntentQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)

  label           String
  description     String
  dominantIntent  IntentCategory
  dominantPhase   TemporalPhase
  percentage      Float          @default(0)
  traits          Json? // 레이더 차트 데이터
  topQuestions    String[]
  contentStrategy String?

  keywords PersonaKeyword[]

  createdAt DateTime @default(now())

  @@index([queryId])
  @@map("personas")
}

/// 페르소나에 연결된 키워드
model PersonaKeyword {
  id        String  @id @default(cuid())
  personaId String
  persona   Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  keyword String
  weight  Float @default(1)

  @@unique([personaId, keyword])
  @@map("persona_keywords")
}

// ============================================
// Listening Mind: Keyword Cluster Result
// ============================================

/// 클러스터 분석 결과 — 영속 저장
model KeywordClusterResult {
  id      String      @id @default(cuid())
  queryId String
  query   IntentQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)

  clusterIndex   Int
  name           String
  centroid       String
  dominantIntent IntentCategory
  dominantPhase  TemporalPhase
  avgGapScore    Float        @default(0)
  avgVolume      Float        @default(0)
  size           Int          @default(0)
  keywords       String[]
  gptAnalysis    Json? // GPT 종합 분석 결과 캐시

  createdAt DateTime @default(now())

  @@index([queryId])
  @@map("keyword_cluster_results")
}

// ============================================
// Listening Mind: Brand Journey (Road View)
// ============================================

/// 브랜드 검색 여정 — 브랜드 간 검색 흐름 추적
model BrandJourney {
  id      String      @id @default(cuid())
  queryId String
  query   IntentQuery @relation(fields: [queryId], references: [id], onDelete: Cascade)

  fromBrand String
  toBrand   String
  weight    Int            @default(0)
  phase     TemporalPhase
  intent    IntentCategory
  context   BrandContext   @default(RELATED)

  createdAt DateTime @default(now())

  @@unique([queryId, fromBrand, toBrand])
  @@index([queryId])
  @@map("brand_journeys")
}

// ── New Enums ──

enum TemporalPhase {
  BEFORE
  CURRENT
  AFTER
}

enum SearchPathType {
  DIRECT       // 직접 연결
  AUTOCOMPLETE // 자동완성 파생
  RELATED      // 연관 검색어
  TEMPORAL     // 시간적 전환
  CO_SEARCH    // 함께 검색
}

enum BrandContext {
  DIRECT      // 직접 검색
  COMPARISON  // 비교 검색
  ALTERNATIVE // 대안 탐색
  RELATED     // 관련 검색
}

// ============================================
// Intelligence: Analysis Run & Snapshot Persistence
// ============================================

/// Intelligence 분석 실행 이력 — 단일 키워드 분석 결과를 시점별로 저장
model IntelligenceAnalysisRun {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Analysis input
  seedKeyword    String
  industryType   String
  industryLabel  String

  // Signal fusion summary
  signalQuality  Json   // { hasClusterData, hasSocialData, hasBenchmarkData, overallRichness }
  fusionResult   Json   // Full SignalFusionResult snapshot

  // Structured output
  taxonomyMapping      Json?  // { coveredCategories, uncoveredCategories, unmappedClusters, totalClusters }
  benchmarkComparison  Json?  // { overallScore, highlights, warnings, comparisons }
  benchmarkBaseline    Json?  // Array of baseline metrics
  socialIntegration    Json?  // { hasSocialData, socialDataQuality, evidenceCount, ... }

  // Intelligence blocks
  additionalInsights  Json?  // Array of insight objects
  additionalWarnings  Json?  // Array of warning strings
  additionalEvidence  Json?  // Array of evidence objects

  // Metadata
  confidence   Float    @default(0)
  freshness    String   @default("fresh")
  isPartial    Boolean  @default(false)
  isMockOnly   Boolean  @default(false)
  isStaleBased Boolean  @default(false)

  // Provider coverage at analysis time
  providerCoverage Json?  // { connectedProviders, totalProviders, isPartial, providers: [...] }

  // Social mention snapshot
  socialMentionSnapshot Json?  // { totalCount, buzzLevel, topicSignals, ... }

  analyzedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([projectId, seedKeyword])
  @@index([projectId, analyzedAt(sort: Desc)])
  @@index([seedKeyword, industryType, analyzedAt(sort: Desc)])
  @@map("intelligence_analysis_runs")
}

/// Intelligence 비교 이력 — A/B 비교 결과 저장
model IntelligenceComparisonRun {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  comparisonType String  // keyword_vs_keyword | industry_vs_industry | period_vs_period

  // Left side reference
  leftLabel       String
  leftKeyword     String
  leftIndustry    String
  leftRunId       String?  // Reference to IntelligenceAnalysisRun.id (optional, for historical)

  // Right side reference
  rightLabel      String
  rightKeyword    String
  rightIndustry   String
  rightRunId      String?  // Reference to IntelligenceAnalysisRun.id (optional, for historical)

  // Comparison result snapshot
  comparisonResult Json   // Full IntelligenceComparisonResult
  overallDifferenceScore Int @default(0)

  // Period comparison metadata
  leftPeriodStart  DateTime?
  leftPeriodEnd    DateTime?
  rightPeriodStart DateTime?
  rightPeriodEnd   DateTime?

  analyzedAt DateTime @default(now())
  createdAt  DateTime @default(now())

  @@index([projectId, analyzedAt(sort: Desc)])
  @@index([projectId, comparisonType])
  @@map("intelligence_comparison_runs")
}

/// Social mention 일별 스냅샷 — 시계열 분석 기반
model SocialMentionSnapshot {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  date      DateTime @db.Date
  keyword   String

  // Aggregated metrics
  totalCount   Int    @default(0)
  buzzLevel    String @default("NONE")  // HIGH | MODERATE | LOW | NONE

  // Sentiment breakdown
  positiveCount      Int @default(0)
  neutralCount       Int @default(0)
  negativeCount      Int @default(0)
  unclassifiedCount  Int @default(0)  // null/unknown sentiment — not analyzed

  // Provider coverage
  providerStatuses Json  // Array of { provider, platform, isConnected, isAvailable, mentionCount }

  // Topic signals
  topicSignals Json?  // Array of TopicSignal

  // Raw mention sample (top 20)
  sampleMentions Json?  // Array of { text, platform, sentiment, publishedAt }

  freshness   String @default("fresh")
  collectedAt DateTime @default(now())

  @@unique([projectId, keyword, date])
  @@index([projectId, keyword, date(sort: Desc)])
  @@map("social_mention_snapshots")
}

/// Benchmark 일별 스냅샷 — 업종별 벤치마크 시계열
model BenchmarkSnapshot {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  date         DateTime @db.Date
  keyword      String
  industryType String

  // Benchmark comparison result
  overallScore Float    @default(0)
  comparisons  Json     // Array of { metricKey, metricLabel, baselineValue, actualValue, deviationPercent, rating }
  highlights   Json?    // Array of highlight strings
  warnings     Json?    // Array of warning strings

  createdAt DateTime @default(now())

  @@unique([projectId, keyword, industryType, date])
  @@index([projectId, keyword, date(sort: Desc)])
  @@map("benchmark_snapshots")
}

/// Intelligence 키워드 이력 — 최근 분석 키워드 + 사용자 북마크
model IntelligenceKeyword {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String

  keyword      String
  industryType String?   // 마지막 분석 시 사용한 업종
  industryLabel String?

  // 상태
  isSaved      Boolean  @default(false)  // 사용자가 북마크한 키워드
  analysisCount Int     @default(1)       // 분석 횟수

  // 마지막 분석 요약
  lastConfidence Float?
  lastFreshness  String?
  lastSignalHint String?  // "RICH" | "MODERATE" | "MINIMAL"

  lastAnalyzedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([projectId, userId, keyword])
  @@index([projectId, userId, lastAnalyzedAt(sort: Desc)])
  @@index([projectId, userId, isSaved])
  @@map("intelligence_keywords")
}

/// 사용자 알림 설정 — 채널/임계값/유형별 개인화
/// projectId가 null이면 user-global 설정, 값이 있으면 project-specific 설정
model UserAlertPreference {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String? // null = global, 값 = project-specific
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 채널 활성 상태
  channelInApp    Boolean @default(true)
  channelEmail    Boolean @default(false)
  channelWebhook  Boolean @default(false)
  webhookUrl      String?

  // Alert type 활성 상태
  enableWarningSpike      Boolean @default(true)
  enableLowConfidence     Boolean @default(true)
  enableBenchmarkDecline  Boolean @default(true)
  enableProviderCoverage  Boolean @default(true)

  // 임계값 커스터마이징
  warningSpike_minCount       Int   @default(3)    // 최소 경고 수
  lowConfidence_threshold     Float @default(0.4)  // 신뢰도 기준 (0-1)
  benchmarkDecline_threshold  Int   @default(15)   // 벤치마크 하락 포인트

  // Guardrail
  globalCooldownMinutes  Int @default(60)  // 최소 쿨다운 (분)
  maxAlertsPerDay        Int @default(20)  // 일일 최대 알림 수

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, projectId])
  @@index([userId])
  @@map("user_alert_preferences")
}
