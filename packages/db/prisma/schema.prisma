// ============================================
// FAQ Intelligence (Phase 2 — 댓글 시작형 Path 3 핵심)
// ============================================

/// 반복 질문 집계. CommentAnalysis.isQuestion=true에서 클러스터링.
model FAQCandidate {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // FAQ 질문 그룹
  question         String
  questionVariants String[]
  category         String?

  // 출처 추적 (polymorphic — Comment ID 목록)
  sourceCommentIds String[]
  mentionCount     Int      @default(0)
  firstSeenAt      DateTime
  lastSeenAt       DateTime

  // 현재 대응 상태
  hasAnswer       Boolean @default(false)
  answerUrl       String?
  answerContentId String?

  // AI 분석
  urgencyScore    Float?
  businessImpact  String?
  suggestedAction String?

  // 상태
  status     FAQStatus @default(DETECTED)
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, question])
  @@index([projectId, status])
  @@index([mentionCount(sort: Desc)])
  @@map("faq_candidates")
}

// ============================================
// Risk Intelligence (Phase 2 — 리스크 감지/에스컬레이션)
// ============================================

/// 부정 감성/위험 댓글 급증 시 리스크 이벤트 단위 관리.
model RiskSignal {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // 리스크 정보
  title       String
  description String?
  riskType    String
  severity    RiskLevel // 기존 enum 재사용

  // 근거 (polymorphic — Comment/Mention ID 목록)
  sourceCommentIds String[]
  sourceMentionIds String[]
  sampleTexts      String[]
  signalCount      Int      @default(0)

  // 시간 범위
  detectedAt      DateTime
  firstOccurrence DateTime
  lastOccurrence  DateTime

  // 상태 관리
  status       RiskSignalStatus @default(ACTIVE)
  assigneeId   String?
  responseNote String?
  resolvedAt   DateTime?

  // AI 분석
  rootCauseAnalysis String?
  recommendedAction String?
  estimatedImpact   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId, status])
  @@index([severity])
  @@index([detectedAt(sort: Desc)])
  @@map("risk_signals")
}

// ============================================
// Notifications (Phase 2 — 운영 알림)
// ============================================

/// 시스템 알림. 수집 실패, 리스크 급증, 토큰 한도 등.
model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  workspaceId String?

  // 알림 내용
  type     NotificationType
  title    String
  message  String
  priority NotificationPriority @default(NORMAL)

  // 출처 (polymorphic — 관련 엔티티 참조)
  sourceType String?
  sourceId   String?
  actionUrl  String?

  // 상태
  isRead Boolean   @default(false)
  readAt DateTime?

  // dismiss / snooze
  isDismissed  Boolean   @default(false)
  dismissedAt  DateTime?
  snoozedUntil DateTime?

  // 발송 채널
  channels    String[]
  emailSentAt DateTime?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("notifications")
}

// ============================================
// Automation Rules & Execution (Phase 9)
// ============================================

/// 자동화 규칙 정의. 트리거 + 조건 + 액션을 하나로 묶는다.
model AutomationRule {
  id          String  @id @default(cuid())
  workspaceId String

  name        String
  description String?

  // 트리거 유형
  triggerType AutomationTriggerType

  // 트리거 조건 (JSON — field, operator, value, description)
  triggerCondition Json

  // 스케줄 (시간 기반 트리거에만 사용)
  cronExpr    String?
  timezone    String  @default("Asia/Seoul")

  // 실행할 액션
  actionType  AutomationActionType
  actionConfig Json   // 액션별 설정 (recipients, template, format 등)

  // 제어
  isEnabled   Boolean @default(true)
  priority    Int     @default(0)

  // 플랜/역할 제한
  requiredPlan Plan?
  allowedRoles String[]

  // 중복 실행 방지
  cooldownMinutes Int @default(60)
  lastTriggeredAt DateTime?

  // 통계
  totalExecutions    Int @default(0)
  successfulExecutions Int @default(0)
  failedExecutions   Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace  Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  executions AutomationExecution[]

  @@index([workspaceId, isEnabled])
  @@index([triggerType])
  @@map("automation_rules")
}

/// 자동화 실행 기록. 모든 자동화 실행은 이 테이블에 기록된다.
model AutomationExecution {
  id     String @id @default(cuid())
  ruleId String
  rule   AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  workspaceId String

  // 실행 상태
  status     AutomationExecutionStatus @default(PENDING)

  // 멱등성 키 (중복 실행 방지)
  idempotencyKey String @unique

  // 트리거 정보
  triggerType    AutomationTriggerType
  triggerPayload Json?

  // 실행 결과
  actionType     AutomationActionType
  actionResult   Json?
  errorMessage   String?

  // 타이밍
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  durationMs  Int?

  // 재시도
  retryCount    Int @default(0)
  maxRetries    Int @default(3)
  nextRetryAt   DateTime?

  createdAt DateTime @default(now())

  deliveries DeliveryLog[]

  @@index([workspaceId, status])
  @@index([ruleId, createdAt(sort: Desc)])
  @@index([status, nextRetryAt])
  @@index([idempotencyKey])
  @@map("automation_executions")
}

/// 발송 기록. 리포트/알림/이메일 등 외부 전달 추적.
model DeliveryLog {
  id          String  @id @default(cuid())
  executionId String?
  execution   AutomationExecution? @relation(fields: [executionId], references: [id], onDelete: Cascade)

  // 발송 대상
  channel     DeliveryChannel
  recipientId String?
  recipientEmail String?

  // 상태
  status      DeliveryStatus @default(PENDING)

  // 결과
  sentAt      DateTime?
  deliveredAt DateTime?
  failedAt    DateTime?
  errorMessage String?

  // 재시도
  retryCount  Int @default(0)
  nextRetryAt DateTime?

  // 참조
  sourceType  String?
  sourceId    String?

  createdAt DateTime @default(now())

  @@index([executionId])
  @@index([status, nextRetryAt])
  @@index([channel, status])
  @@map("delivery_logs")
}

